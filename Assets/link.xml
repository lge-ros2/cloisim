<linker>
	<!--
	CloisimProtoModel.dll (generated by Assets/Editor/ProtoModelCompiler.cs) contains
	no reflection-based scanning at runtime, but its generated serializer code still
	accesses cloisim.msgs.* properties by name-independent IL (direct get/set calls),
	which IL2CPP's managedStrippingLevel=High can otherwise remove as "unused" since
	nothing else in the call graph references every property on every message type.
	-->
	<assembly fullname="Assembly-CSharp">
		<namespace fullname="cloisim.msgs" preserve="all" />
	</assembly>
	<assembly fullname="CloisimProtoModel" preserve="all" />
</linker>
